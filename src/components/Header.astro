---
const withBase = (path) => `${import.meta.env.BASE_URL.replace(/\/$/, '')}${path}`;

const navLinks = [
  { href: withBase('/'), label: 'Home' },
  { href: withBase('/capabilities'), label: 'Capabilities' },
  { href: withBase('/industries'), label: 'Industries' },
  { href: withBase('/about'), label: 'About' },
  { href: withBase('/contact'), label: 'Contact' },
  { href: withBase('/request-access'), label: 'Request Access' }
];
---

<header class="sticky top-0 z-20 border-b border-slate-800 bg-slate-950/95 backdrop-blur">
  <div class="mx-auto flex max-w-6xl flex-wrap items-center justify-between gap-4 px-4 py-4 sm:px-6 lg:px-8">
    <a href={withBase('/')} class="text-lg font-semibold tracking-tight text-white">Foremost Machine, Inc.</a>
    <span class="rounded-full border border-brand-500/70 bg-brand-700/40 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-brand-100">Commercial Accounts Only</span>
    <nav aria-label="Primary">
      <ul class="flex flex-wrap gap-4 text-sm text-slate-300">
        {navLinks.map((link) => (
          <li><a class="hover:text-white" href={link.href}>{link.label}</a></li>
        ))}
      </ul>
    </nav>
  </div>
</header>
